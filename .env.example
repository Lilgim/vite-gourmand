# PostgreSQL — données relationnelles (utilisateurs, menus, commandes, avis)
# Valeurs par défaut du docker-compose.yml de dev :
DATABASE_URL="postgresql://vg:vg_dev_password@localhost:5433/vite_gourmand"

# MongoDB — statistiques administrateur
MONGODB_URI="mongodb://localhost:27018/vite_gourmand_stats"

# Secret de session/auth (générer une valeur aléatoire longue)
AUTH_SECRET="changez-moi"
APP_URL="http://localhost:3000"

# Emails transactionnels (environnement de test documenté dans docs/)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="no-reply@vite-gourmand.example"
CONTACT_EMAIL="contact@vite-gourmand.example"
