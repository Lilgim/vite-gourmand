# Modèle du .env de production (VPS). Copier en .env sur le serveur,
# remplir, ne JAMAIS commiter le fichier rempli.

# Domaine public de l'application (enregistrement DNS A -> IP du VPS)
DOMAIN="vite-gourmand.example.fr"

# Email pour les certificats Let's Encrypt (Caddy)
ACME_EMAIL="admin@example.fr"

# Générer : openssl rand -hex 24
POSTGRES_PASSWORD=""

# Générer : openssl rand -hex 32
AUTH_SECRET=""

# Expéditeur des emails transactionnels (mode test : journalisés, pas envoyés)
EMAIL_FROM="no-reply@vite-gourmand.example"

# Port loopback de l'app sur l'hôte (cas "reverse proxy existant")
# APP_PORT="3001"
